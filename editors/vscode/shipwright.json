{
  "manifestVersion": 1,
  "product": {
    "id": "sharplsp",
    "displayName": "SharpLsp",
    "version": "0.1.0",
    "repository": "https://github.com/Nimblesite/SharpLsp"
  },
  "components": [
    {
      "id": "sharplsp",
      "kind": "lsp",
      "language": "rust",
      "binaryName": "sharplsp",
      "expectedVersion": "${PRODUCT_VERSION}",
      "platforms": [
        "darwin-arm64",
        "darwin-x64",
        "linux-x64",
        "linux-arm64",
        "win32-x64",
        "win32-arm64"
      ],
      "bundled": {
        "bundlePath": "bin/${platform}/sharplsp${exe}",
        "perPlatformArtifact": true
      },
      "sources": [
        "user-setting",
        "env",
        "bundled",
        "path",
        "pkgmgr"
      ],
      "userSetting": "sharplsp.lspPath",
      "env": {
        "pathVar": "SHARPLSP_LSP_PATH",
        "dirVar": "SHARPLSP_BINARY_DIR"
      },
      "pkgmgr": {
        "brew": "nimblesite/tap/sharplsp",
        "scoop": "nimblesite/sharplsp"
      },
      "verifyStartup": true,
      "versionCheckStrategy": "version-flag"
    },
    {
      "id": "sharplsp-sidecar-csharp",
      "kind": "sidecar",
      "language": "dotnet",
      "binaryName": "sharplsp-sidecar-csharp",
      "expectedVersion": "${PRODUCT_VERSION}",
      "platforms": [
        "all"
      ],
      "bundled": {
        "bundlePath": "bin/all/sharplsp-sidecar-csharp",
        "perPlatformArtifact": false
      },
      "sources": [
        "user-setting",
        "env",
        "bundled",
        "path"
      ],
      "userSetting": "sharplsp.csharpSidecarPath",
      "env": {
        "pathVar": "SHARPLSP_CSHARP_SIDECAR_PATH"
      },
      "verifyStartup": true,
      "versionCheckStrategy": "version-flag"
    },
    {
      "id": "sharplsp-sidecar-fsharp",
      "kind": "sidecar",
      "language": "dotnet",
      "binaryName": "sharplsp-sidecar-fsharp",
      "expectedVersion": "${PRODUCT_VERSION}",
      "platforms": [
        "all"
      ],
      "bundled": {
        "bundlePath": "bin/all/sharplsp-sidecar-fsharp",
        "perPlatformArtifact": false
      },
      "sources": [
        "user-setting",
        "env",
        "bundled",
        "path"
      ],
      "userSetting": "sharplsp.fsharpSidecarPath",
      "env": {
        "pathVar": "SHARPLSP_FSHARP_SIDECAR_PATH"
      },
      "verifyStartup": true,
      "versionCheckStrategy": "version-flag"
    },
    {
      "id": "sharplsp-vscode",
      "kind": "extension-vscode",
      "language": "typescript",
      "platforms": [
        "all"
      ]
    },
    {
      "id": "sharplsp-zed",
      "kind": "extension-zed",
      "language": "rust",
      "platforms": [
        "all"
      ]
    },
    {
      "id": "sharplsp-rider",
      "kind": "extension-jetbrains",
      "language": "kotlin",
      "platforms": [
        "all"
      ]
    }
  ],
  "hosts": {
    "vscode": {
      "artifact": "vsix-per-platform",
      "activationVerifies": [
        "sharplsp",
        "sharplsp-sidecar-csharp",
        "sharplsp-sidecar-fsharp"
      ],
      "onMismatch": "prompt-pkgmgr"
    },
    "jetbrains": {
      "artifact": "intellij-jar",
      "activationVerifies": [
        "sharplsp",
        "sharplsp-sidecar-csharp",
        "sharplsp-sidecar-fsharp"
      ],
      "onMismatch": "prompt-pkgmgr"
    },
    "zed": {
      "artifact": "zed-wasm",
      "activationVerifies": [
        "sharplsp"
      ],
      "onMismatch": "error"
    },
    "cli": {
      "artifact": "archive"
    },
    "pkgmgr": {
      "artifact": "brew-formula"
    }
  }
}
