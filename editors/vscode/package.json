    "menus": {
      "view/title": [
        {
          "command": "forge.selectSolution",
          "when": "view == forge.solutionExplorer",
          "group": "navigation"
        },
        {
          "command": "forge.refreshExplorer",
          "when": "view == forge.solutionExplorer",
          "group": "navigation"
        },
        {
          "command": "forge.sortNatural",
          "when": "view == forge.solutionExplorer && forge.sortOrder == natural",
          "group": "navigation"
        },
        {
          "command": "forge.sortAlphabetical",
          "when": "view == forge.solutionExplorer && forge.sortOrder == alphabetical",
          "group": "navigation"
        },
        {
          "command": "forge.sortAccessibility",
          "when": "view == forge.solutionExplorer && forge.sortOrder == accessibility",
          "group": "navigation"
        },
        {
          "command": "forge.profiler.refresh",
          "when": "view == forge.profiler",
          "group": "navigation@1"
        },
        {
          "command": "forge.profiler.openTrace",
          "when": "view == forge.profiler",
          "group": "navigation@2"
        },
        {
          "command": "forge.profiler.startTrace",
          "when": "view == forge.profiler",
          "group": "overflow@1"
        },
        {
          "command": "forge.profiler.startCounters",
          "when": "view == forge.profiler",
          "group": "overflow@2"
        },
        {
          "command": "forge.profiler.collectDump",
          "when": "view == forge.profiler",
          "group": "overflow@3"
        },
        {
          "command": "forge.profiler.convertTrace",
          "when": "view == forge.profiler",
          "group": "overflow@4"
        },
        {
          "command": "forge.profiler.analyzeHeap",
          "when": "view == forge.profiler",
          "group": "overflow@5"
        },
        {
          "command": "forge.profiler.diffSnapshots",
          "when": "view == forge.profiler",
          "group": "overflow@6"
        },
        {
          "command": "forge.profiler.detectLeaks",
          "when": "view == forge.profiler",
          "group": "overflow@7"
        }
      ],
      "debug/toolbar": [
        {
          "command": "forge.hotReload.toggle",
          "when": "debugType == forge-coreclr && !forge.hotReloadRunning",
          "group": "navigation"
        },
        {
          "command": "forge.hotReload.stop",
          "when": "debugType == forge-coreclr && forge.hotReloadRunning",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "forge.sortMembers",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\.(class|struct|interface|enum|record)$/",
          "group": "1_modification"
        },
        {
          "command": "forge.revealInExplorer",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\./",
          "group": "3_open"
        },
        {
          "command": "forge.removeNuGetPackage",
          "when": "view == forge.solutionExplorer && viewItem == nugetPackage",
          "group": "7_modification"
        },
        {
          "command": "forge.removeProjectReference",
          "when": "view == forge.solutionExplorer && viewItem == projectReference",
          "group": "7_modification"
        },
        {
          "command": "forge.openProjectFile",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "3_open"
        },
        {
          "command": "forge.browseNuGetPackages",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "5_dependencies"
        },
        {
          "command": "forge.build",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "2_build"
        },
        {
          "command": "forge.rebuild",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "2_build"
        },
        {
          "command": "forge.clean",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "2_build"
        },
        {
          "command": "forge.addProjectReference",
          "when": "view == forge.solutionExplorer && viewItem == dependencyFolder",
          "group": "1_add"
        },
        {
          "command": "forge.nuget.addFromExplorer",
          "when": "view == forge.solutionExplorer && viewItem == dependencyFolder",
          "group": "1_add"
        },
        {
          "command": "forge.copyQualifiedName",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\./",
          "group": "9_cutcopypaste"
        },
        {
          "command": "forge.copyName",
          "when": "view == forge.solutionExplorer && viewItem =~ /^(symbol\\.|solution$|project$)/",
          "group": "9_cutcopypaste"
        },
        {
          "command": "forge.profiler.stopSession",
          "when": "view == forge.profiler && viewItem == profiler-session-trace",
          "group": "inline@1"
        },
        {
          "command": "forge.profiler.stopSession",
          "when": "view == forge.profiler && viewItem == profiler-session-trace",
          "group": "1_stop@1"
        },
        {
          "command": "forge.profiler.revealOutput",
          "when": "view == forge.profiler && viewItem == profiler-session-trace",
          "group": "2_open@1"
        },
        {
          "command": "forge.profiler.copyOutputPath",
          "when": "view == forge.profiler && viewItem == profiler-session-trace",
          "group": "9_copy@1"
        },
        {
          "command": "forge.profiler.showCountersPanel",
          "when": "view == forge.profiler && viewItem == profiler-session-counters",
          "group": "inline@1"
        },
        {
          "command": "forge.profiler.showCountersPanel",
          "when": "view == forge.profiler && viewItem == profiler-session-counters",
          "group": "1_show@1"
        },
        {
          "command": "forge.profiler.stopCounters",
          "when": "view == forge.profiler && viewItem == profiler-session-counters",
          "group": "1_show@2"
        },
        {
          "command": "forge.profiler.traceProcess",
          "when": "view == forge.profiler && viewItem == profiler-process",
          "group": "inline@1"
        },
        {
          "command": "forge.profiler.traceProcess",
          "when": "view == forge.profiler && viewItem == profiler-process",
          "group": "1_profile@1"
        },
        {
          "command": "forge.profiler.countersProcess",
          "when": "view == forge.profiler && viewItem == profiler-process",
          "group": "1_profile@2"
        },
        {
          "command": "forge.profiler.dumpProcess",
          "when": "view == forge.profiler && viewItem == profiler-process",
          "group": "1_profile@3"
        },
        {
          "command": "forge.profiler.copyPid",
          "when": "view == forge.profiler && viewItem == profiler-process",
          "group": "9_copy@1"
        }
      ]
    }
  },
  "scripts": {
