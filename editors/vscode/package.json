          "id": "forge.solutionExplorer",
          "name": "Solution Explorer",
          "icon": "icons/forge.svg"
        },
        {
          "id": "forge.profiler",
          "name": "Profiler",
          "icon": "$(pulse)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "forge.solutionExplorer",
        "contents": "No .sln files found in this workspace."
      }
    ],
