{
  "name": "forge",
  "displayName": "Forge",
  "description": "The open-source .NET Language Server — C# and F# intelligence for every editor. Zero licenses. Zero vendor lock-in.",
  "version": "0.1.0",
  "publisher": "forge-lsp",
  "license": "MIT",
  "icon": "icons/forge.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "C#",
    "F#",
    "csharp",
    "fsharp",
    ".NET",
    "dotnet",
    "Roslyn",
    "LSP",
    "language server"
  ],
  "galleryBanner": {
    "color": "#0a1a12",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-lsp/forge"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.fsproj"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "csharp",
        "aliases": [
          "C#",
          "CSharp"
        ],
        "extensions": [
          ".cs",
          ".csx"
        ],
        "configuration": "./language-configuration/csharp.json"
      },
      {
        "id": "fsharp",
        "aliases": [
          "F#",
          "FSharp"
        ],
        "extensions": [
          ".fs",
          ".fsx",
          ".fsi"
        ],
        "configuration": "./language-configuration/fsharp.json"
      }
    ],
    "configuration": {
      "title": "Forge",
      "properties": {
        "forge.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `forge-lsp` binary. Leave empty to use the system-installed binary from `~/.local/bin/` or `$PATH`.",
          "scope": "machine-overridable",
          "order": 0
        },
        "forge.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra arguments passed to the `forge-lsp` process.",
          "scope": "machine-overridable",
          "order": 1
        },
        "forge.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication between VS Code and the Forge server.",
          "scope": "window",
          "order": 2
        },
        "forge.logging.level": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "markdownDescription": "Log level for the Forge server (maps to `RUST_LOG`).",
          "scope": "window",
          "order": 3
        },
        "forge.memberSortOrder.hierarchy": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "accessibility",
              "category",
              "alphabetical"
            ]
          },
          "default": [
            "accessibility",
            "category",
            "alphabetical"
          ],
          "markdownDescription": "Sort tiebreaker order for **Sort Members**. Members are grouped by the first criterion, then sub-sorted by the second, then the third.",
          "scope": "resource",
          "order": 10
        },
        "forge.memberSortOrder.accessibilityOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "public",
            "protected internal",
            "internal",
            "protected",
            "private protected",
            "private"
          ],
          "markdownDescription": "Access modifier priority for **Sort Members** (first = highest priority).",
          "scope": "resource",
          "order": 11
        },
        "forge.memberSortOrder.categoryOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "constant",
            "field",
            "constructor",
            "finalizer",
            "delegate",
            "event",
            "enum",
            "interface",
            "property",
            "indexer",
            "operator",
            "method",
            "struct",
            "class",
            "record"
          ],
          "markdownDescription": "Member kind priority for **Sort Members** (first = highest priority).",
          "scope": "resource",
          "order": 12
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge-explorer",
          "title": "Forge",
          "icon": "icons/forge-activity.svg"
        }
      ]
    },
    "views": {
      "forge-explorer": [
        {
          "id": "forge.solutionExplorer",
          "name": "Solution Explorer",
          "icon": "icons/forge.svg"
        },
        {
          "id": "forge.profiler",
          "name": "Profiler",
          "icon": "$(pulse)"
        }
      ]
    },
    "commands": [
      {
        "command": "forge.restartServer",
        "title": "Restart Language Server",
        "category": "Forge"
      },
      {
        "command": "forge.showOutput",
        "title": "Show Output Channel",
        "category": "Forge"
      },
      {
        "command": "forge.showTraceOutput",
        "title": "Show Trace Output",
        "category": "Forge"
      },
      {
        "command": "forge.selectSolution",
        "title": "Select Solution",
        "category": "Forge",
        "icon": "$(folder-opened)"
      },
      {
        "command": "forge.refreshExplorer",
        "title": "Refresh Explorer",
        "category": "Forge",
        "icon": "$(refresh)"
      },
      {
        "command": "forge.sortNatural",
        "title": "Sort: Source Order",
        "category": "Forge",
        "icon": "$(list-ordered)"
      },
      {
        "command": "forge.sortAlphabetical",
        "title": "Sort: Alphabetical",
        "category": "Forge",
        "icon": "$(case-sensitive)"
      },
      {
        "command": "forge.sortAccessibility",
        "title": "Sort: Accessibility",
        "category": "Forge",
        "icon": "$(shield)"
      },
      {
        "command": "forge.removeNuGetPackage",
        "title": "Remove Package",
        "category": "Forge",
        "icon": "$(trash)"
      },
      {
        "command": "forge.removeProjectReference",
        "title": "Remove Project Reference",
        "category": "Forge",
        "icon": "$(trash)"
      },
      {
        "command": "forge.browseNuGetPackages",
        "title": "Browse NuGet Packages",
        "category": "Forge",
        "icon": "$(package)"
      },
      {
        "command": "forge.sortMembers",
        "title": "Sort Members",
        "category": "Forge",
        "icon": "$(list-ordered)"
      },
      {
        "command": "forge.copyQualifiedName",
        "title": "Copy Qualified Name",
        "category": "Forge"
      },
      {
        "command": "forge.copyName",
        "title": "Copy Name",
        "category": "Forge"
      },
      {
        "command": "forge.revealInExplorer",
        "title": "Reveal in File Explorer",
        "category": "Forge",
        "icon": "$(go-to-file)"
      },
      {
        "command": "forge.profiler.listProcesses",
        "title": "List .NET Processes",
        "category": "Forge"
      },
      {
        "command": "forge.profiler.startTrace",
        "title": "Start Performance Trace",
        "category": "Forge",
        "icon": "$(record)"
      },
      {
        "command": "forge.profiler.stopTrace",
        "title": "Stop Performance Trace",
        "category": "Forge",
        "icon": "$(debug-stop)"
      },
      {
        "command": "forge.profiler.startCounters",
        "title": "Start Counter Monitoring",
        "category": "Forge",
        "icon": "$(pulse)"
      },
      {
        "command": "forge.profiler.stopCounters",
        "title": "Stop Counter Monitoring",
        "category": "Forge",
        "icon": "$(debug-stop)"
      },
      {
        "command": "forge.profiler.collectDump",
        "title": "Collect Memory Dump",
        "category": "Forge",
        "icon": "$(database)"
      },
      {
        "command": "forge.profiler.analyzeHeap",
        "title": "Analyze Heap Dump",
        "category": "Forge",
        "icon": "$(graph)"
      },
      {
        "command": "forge.profiler.refresh",
        "title": "Refresh Profiler",
        "category": "Forge",
        "icon": "$(refresh)"
      },
      {
        "command": "forge.profiler.diffSnapshots",
        "title": "Compare Heap Snapshots",
        "category": "Forge",
        "icon": "$(diff)"
      },
      {
        "command": "forge.profiler.detectLeaks",
        "title": "Detect Memory Leaks",
        "category": "Forge",
        "icon": "$(warning)"
      },
      {
        "command": "forge.profiler.showObjectGraph",
        "title": "Show Object Retention Graph",
        "category": "Forge",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "forge.profiler.inspectObject",
        "title": "Inspect Object",
        "category": "Forge",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forge.selectSolution",
          "when": "view == forge.solutionExplorer",
          "group": "navigation"
        },
        {
          "command": "forge.refreshExplorer",
          "when": "view == forge.solutionExplorer",
          "group": "navigation"
        },
        {
          "command": "forge.sortNatural",
          "when": "view == forge.solutionExplorer && forge.sortOrder == natural",
          "group": "navigation"
        },
        {
          "command": "forge.sortAlphabetical",
          "when": "view == forge.solutionExplorer && forge.sortOrder == alphabetical",
          "group": "navigation"
        },
        {
          "command": "forge.sortAccessibility",
          "when": "view == forge.solutionExplorer && forge.sortOrder == accessibility",
          "group": "navigation"
        },
        {
          "command": "forge.profiler.refresh",
          "when": "view == forge.profiler",
          "group": "navigation"
        },
        {
          "command": "forge.profiler.startTrace",
          "when": "view == forge.profiler",
          "group": "navigation"
        },
        {
          "command": "forge.profiler.startCounters",
          "when": "view == forge.profiler",
          "group": "navigation"
        },
        {
          "command": "forge.profiler.collectDump",
          "when": "view == forge.profiler",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "forge.sortMembers",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\.(class|struct|interface|enum|record)$/",
          "group": "1_modification"
        },
        {
          "command": "forge.revealInExplorer",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\./",
          "group": "3_open"
        },
        {
          "command": "forge.removeNuGetPackage",
          "when": "view == forge.solutionExplorer && viewItem == nugetPackage",
          "group": "7_modification"
        },
        {
          "command": "forge.removeProjectReference",
          "when": "view == forge.solutionExplorer && viewItem == projectReference",
          "group": "7_modification"
        },
        {
          "command": "forge.browseNuGetPackages",
          "when": "view == forge.solutionExplorer && viewItem == project",
          "group": "5_dependencies"
        },
        {
          "command": "forge.copyQualifiedName",
          "when": "view == forge.solutionExplorer && viewItem =~ /^symbol\\./",
          "group": "9_cutcopypaste"
        },
        {
          "command": "forge.copyName",
          "when": "view == forge.solutionExplorer && viewItem =~ /^(symbol\\.|solution$|project$)/",
          "group": "9_cutcopypaste"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ && tsc --noEmit",
    "lint:eslint": "eslint src/",
    "compile-tests": "tsc -p ./",
    "pretest": "npm run compile-tests",
    "test": "vscode-test --coverage",
    "test:run": "node out/test/runTest.js",
    "screenshots": "node screenshots/capture.mjs",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "eslint": "^10.0.3",
    "glob": "^11.0.0",
    "mocha": "^10.7.0",
    "playwright": "^1.58.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1"
  }
}
