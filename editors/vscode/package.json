{
  "name": "forge",
  "displayName": "Forge",
  "description": "The open-source .NET Language Server — C# and F# intelligence for every editor. Zero licenses. Zero vendor lock-in.",
  "version": "0.1.0",
  "publisher": "forge-lsp",
  "license": "MIT",
  "icon": "icons/forge.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "C#",
    "F#",
    "csharp",
    "fsharp",
    ".NET",
    "dotnet",
    "Roslyn",
    "LSP",
    "language server"
  ],
  "galleryBanner": {
    "color": "#0a1a12",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nimblesite/forge"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.fsproj"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "csharp",
        "aliases": [
          "C#",
          "CSharp"
        ],
        "extensions": [
          ".cs",
          ".csx"
        ],
        "configuration": "./language-configuration/csharp.json"
      },
      {
        "id": "fsharp",
        "aliases": [
          "F#",
          "FSharp"
        ],
        "extensions": [
          ".fs",
          ".fsx",
          ".fsi"
        ],
        "configuration": "./language-configuration/fsharp.json"
      }
    ],
    "configuration": {
      "title": "Forge",
      "properties": {
        "forge.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `forge-lsp` binary. Leave empty to use the system-installed binary from `~/.local/bin/` or `$PATH`.",
          "scope": "machine-overridable",
          "order": 0
        },
        "forge.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra arguments passed to the `forge-lsp` process.",
          "scope": "machine-overridable",
          "order": 1
        },
        "forge.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication between VS Code and the Forge server.",
          "scope": "window",
          "order": 2
        },
        "forge.logging.level": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "markdownDescription": "Log level for the Forge server (maps to `RUST_LOG`).",
          "scope": "window",
          "order": 3
        },
        "forge.debug.netcoredbgPath": {
          "type": "string",
          "default": "",
          "description": "Path to netcoredbg executable. Leave empty for auto-detection.",
          "scope": "machine",
          "order": 20
        },
        "forge.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints in method calls.",
          "scope": "resource",
          "order": 5
        },
        "forge.inlayHints.typeInference": {
          "type": "boolean",
          "default": true,
          "description": "Show type inference hints for var declarations and lambdas.",
          "scope": "resource",
          "order": 6
        },
        "forge.inlayHints.pipelineTypes": {
          "type": "boolean",
          "default": true,
          "description": "Show type hints for F# pipeline operators.",
          "scope": "resource",
          "order": 7
        },
        "forge.nuget.includePrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Include prerelease versions in NuGet package search results.",
          "scope": "resource",
          "order": 15
        },
        "forge.hotReload.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start hot reload on file save when a dotnet watch session is active.",
          "scope": "resource",
          "order": 16
        },
        "forge.testLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show pass/fail status, Run Test, and Debug Test lenses above test methods.",
          "scope": "resource",
          "order": 17
        },
        "forge.memberSortOrder.hierarchy": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "accessibility",
              "category",
              "alphabetical"
            ]
          },
          "default": [
            "accessibility",
            "category",
            "alphabetical"
          ],
          "markdownDescription": "Sort tiebreaker order for **Sort Members**. Members are grouped by the first criterion, then sub-sorted by the second, then the third.",
          "scope": "resource",
          "order": 10
        },
        "forge.memberSortOrder.accessibilityOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "public",
            "protected internal",
            "internal",
            "protected",
            "private protected",
            "private"
          ],
          "markdownDescription": "Access modifier priority for **Sort Members** (first = highest priority).",
          "scope": "resource",
          "order": 11
        },
        "forge.memberSortOrder.categoryOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "constant",
            "field",
            "constructor",
            "finalizer",
            "delegate",
            "event",
            "enum",
            "interface",
            "property",
            "indexer",
            "operator",
            "method",
            "struct",
            "class",
            "record"
          ],
          "markdownDescription": "Member kind priority for **Sort Members** (first = highest priority).",
          "scope": "resource",
          "order": 12
        }
      }
    },
    "debuggers": [
      {
        "type": "forge-coreclr",
        "label": "Forge .NET Debugger",
        "languages": [
          "csharp",
          "fsharp"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .NET assembly to debug."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command line arguments.",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory."
              },
              "env": {
                "type": "object",
                "description": "Environment variables."
              },
              "stopAtEntry": {
                "type": "boolean",
                "description": "Break at the entry point.",
                "default": false
              }
            }
          },
          "attach": {
            "required": [
              "processId"
            ],
            "properties": {
              "processId": {
                "type": "number",
                "description": "Process ID to attach to."
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Forge: Launch .NET Project",
            "description": "Launch a .NET project with Forge debugger",
            "body": {
              "type": "forge-coreclr",
              "request": "launch",
              "name": "Launch .NET Project",
              "program": "${workspaceFolder}/bin/Debug/net9.0/${workspaceFolderBasename}.dll",
              "cwd": "${workspaceFolder}",
              "stopAtEntry": false
            }
          },
          {
            "label": "Forge: Attach to .NET Process",
            "description": "Attach to a running .NET process",
            "body": {
              "type": "forge-coreclr",
              "request": "attach",
              "name": "Attach to Process",
              "processId": 0
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge-explorer",
          "title": "Forge",
          "icon": "icons/forge-activity.svg"
        }
      ]
    },
    "views": {
      "forge-explorer": [
