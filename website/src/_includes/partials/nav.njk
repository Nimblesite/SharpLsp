<nav class="nav">
  <a href="{% if lang and lang != defaultLanguage %}/{{ lang }}/{% else %}/{% endif %}" class="logo">
    <img class="logo-mark" src="/assets/favicon.svg" alt="" width="24" height="24">{{ site.name | default(site.title) }}
  </a>

  {% set lp = "/" + lang + "/" if lang and lang != defaultLanguage else "/" %}
  {% set docsRoot = lp + "docs/" %}
  <ul class="nav-links">
    <li><a class="nav-link {% if page.url.startsWith('/docs/') or page.url.startsWith('/' + lang + '/docs/') %}active{% endif %}" href="{{ docsRoot }}">{{ "nav.docs" | t(lang) | default("Docs") }}</a></li>
    <li><a class="nav-link {% if page.url.startsWith('/blog/') or page.url.startsWith('/' + lang + '/blog/') %}active{% endif %}" href="{{ lp }}blog/">{{ "nav.blog" | t(lang) | default("Blog") }}</a></li>
    <li><a class="nav-link" href="https://github.com/Nimblesite/SharpLsp">GitHub</a></li>
  </ul>

  <div class="nav-actions">
    <a class="nav-button" href="{{ docsRoot }}">{{ "docs.gettingStarted" | t(lang) | default("Get Started") }}</a>

    {% if techdocOptions.features.i18n and (supportedLanguages | length) > 1 %}
    {% set currentLangCode = lang | default('en') %}
    {% set currentLanguage = languages[currentLangCode] if languages and languages[currentLangCode] else null %}
    <div class="language-switcher">
      <button class="language-btn" aria-label="Select language" aria-expanded="false">
        <span class="language-label">
          {% if currentLanguage and currentLanguage.flag %}<span class="language-flag" aria-hidden="true">{{ currentLanguage.flag }}</span>{% endif %}
          <span>{% if currentLanguage %}{{ currentLanguage.nativeName }}{% else %}{{ currentLangCode | upper }}{% endif %}</span>
        </span>
      </button>
      <ul class="language-dropdown" role="menu">
        {% for langCode in supportedLanguages %}
        {% set targetLanguage = languages[langCode] if languages and languages[langCode] else null %}
        <li role="menuitem">
          <a href="{{ page.url | altLangUrl(lang | default('en'), langCode) }}" class="{% if (lang | default('en')) == langCode %}active{% endif %}" lang="{{ langCode }}">
            <span class="language-label">
              {% if targetLanguage and targetLanguage.flag %}<span class="language-flag" aria-hidden="true">{{ targetLanguage.flag }}</span>{% endif %}
              <span>{% if targetLanguage %}{{ targetLanguage.nativeName }}{% else %}{{ langCode | upper }}{% endif %}</span>
            </span>
          </a>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if techdocOptions.features.darkMode %}
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
      <span class="theme-icon-light">☀</span>
      <span class="theme-icon-dark">☾</span>
    </button>
    {% endif %}

    <button id="mobile-menu-toggle" class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
