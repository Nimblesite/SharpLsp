<a class="article-author" href="/author/{{ author | default('sharplsp-contributors') | slugify }}/">
  <img src="{{ authorImage | default('/assets/images/sharplsp-avatar.png') }}" alt="{{ author | default('SharpLsp Team') }}" onerror="this.style.display='none'">
  <div>
    <p>{{ author | default("SharpLsp Team") }}</p>
    <small>{{ authorRole | default("Principal Distributed Systems Engineer") }}</small>
  </div>
</a>
