{% set authorName = author | default("SharpLsp Team") %}
{% set authorData = collections.authorsByName[authorName] %}
{% set resolvedImage = authorData.authorImage | default('/assets/images/sharplsp-logo.svg') %}
{% set resolvedRole = authorData.authorRole | default("Nimblesite Engineering") %}
<a class="article-author" href="/author/{{ authorName | slugify }}/">
  <img src="{{ resolvedImage }}" alt="{{ authorName }}" onerror="this.style.display='none'">
  <div>
    <p>{{ authorName }}</p>
    <small>{{ resolvedRole }}</small>
  </div>
</a>
