{% macro postCard(post, featured) %}
<article class="post-card{% if featured %} post-card-featured{% endif %}">
  <a class="post-media{% if not post.data.image %} post-media-symbol{% endif %}" href="{{ post.url }}" aria-label="{{ post.data.title }}">
    {% if post.data.image %}
    <img src="{{ post.data.image }}" alt="{{ post.data.imageAlt | default(post.data.title) }}" loading="lazy">
    {% else %}
    <span class="material-symbols-outlined" aria-hidden="true">article</span>
    {% endif %}
  </a>
  <div class="post-body">
    {% if post.data.tags %}
    <div class="post-tags">
      {%- for tag in post.data.tags -%}
      {%- if tag != 'post' and tag != 'posts' -%}
      <a href="/blog/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
      {%- endif -%}
      {%- endfor -%}
    </div>
    {% endif %}
    <h2 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.excerpt or post.data.description %}
    <p class="post-excerpt">{{ post.data.excerpt | default(post.data.description) }}</p>
    {% endif %}
    <div class="post-meta">
      <a class="post-author" href="/author/{{ post.data.author | default('forge-team') | slugify }}/">
        {% if post.data.authorImage %}
        <img src="{{ post.data.authorImage }}" alt="{{ post.data.author | default('Forge Team') }}">
        {% else %}
        <strong>{{ post.data.author | default("FO") | truncate(2, false, "") | upper }}</strong>
        {% endif %}
        <div>
          <span>{{ post.data.author | default("Forge Team") }}</span>
          <small>{{ post.date | dateFormat }}</small>
        </div>
      </a>
      {% if featured %}<span class="read-time">8 min read</span>{% endif %}
    </div>
  </div>
</article>
{% endmacro %}
