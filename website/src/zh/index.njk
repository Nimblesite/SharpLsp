<section class="masthead">
  <div class="badge"><span class="status-dot"></span>v1.0.4 Now Available</div>
  <h1 class="title">The Future of <span>.NET Tooling</span></h1>
  <p class="lede">
    Engineered in Rust for uncompromising speed. Forge is a high-performance
    workspace designed for developers who value precision and productivity
    over bloat.
  </p>
  <div class="button-row">
    <a class="button button-primary" href="/zh/docs/">Get Started</a>
    <a class="button button-secondary" href="https://github.com/MelbourneDeveloper/forge">
      <span class="material-symbols-outlined" aria-hidden="true">code</span>
      View on GitHub
    </a>
  </div>
</section>

<section class="panel">
  <div class="card-grid card-grid-three">
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">bolt</span>
      <h2>&lt;3s</h2>
      <p>Cold Start</p>
    </article>
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">speed</span>
      <h2>&lt;100ms</h2>
      <p>Completions</p>
    </article>
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">extension_off</span>
      <h2>0</h2>
      <p>Proprietary Dependencies</p>
    </article>
  </div>
</section>

<section class="band">
  <div class="copy-block">
    <h2>Uncompromising Performance</h2>
    <p>Write, debug, and profile your .NET code in a pure, native environment.</p>
  </div>

  <div class="window">
    <div class="window-bar">
      <div class="window-controls" aria-hidden="true">
        <span class="window-dot window-dot-red"></span>
        <span class="window-dot window-dot-yellow"></span>
        <span class="window-dot window-dot-green"></span>
      </div>
      <div class="window-title">Program.cs — Forge</div>
      <div class="window-tools" aria-hidden="true">
        <span class="material-symbols-outlined">play_arrow</span>
        <span class="material-symbols-outlined">bug_report</span>
      </div>
    </div>
    <pre class="code-pane"><code><span class="token-keyword">using</span> System;
<span class="token-keyword">using</span> System.Diagnostics;

<span class="token-keyword">namespace</span> Forge.Demo
{
    <span class="token-keyword">public class</span> Program
    {
        <span class="token-keyword">public static void</span> Main()
        {
            <span class="token-type">var</span> sw = Stopwatch.StartNew();

            Console.WriteLine(<span class="token-string">"Initializing Forge workspace..."</span>);

            <span class="token-comment">// Zero-allocation parsing</span>
            <span class="token-type">var</span> parser = <span class="token-keyword">new</span> FastSyntaxParser();
            parser.AnalyzeProject();

            sw.Stop();
            Console.WriteLine(<span class="token-string">$"Ready in {sw.ElapsedMilliseconds}ms"</span>);
        }
    }
}</code></pre>
  </div>
</section>

