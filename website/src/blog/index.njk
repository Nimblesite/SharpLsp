---
layout: layouts/base.njk
title: Engineering Blog
permalink: /blog/
---
{% from "partials/post-card.njk" import postCard %}
<div class="blog-container">
  <header class="blog-header">
    <h1>Engineering Blog</h1>
    <p class="blog-subtitle">Deep dives into systems architecture, performance tuning, and the technical decisions behind Forge. Built by engineers, for engineers.</p>
  </header>

  <div class="blog-filter">
    <ul class="filter-list">
      <li><a class="filter-chip filter-chip-active" href="/blog/">All</a></li>
      <li><a class="filter-chip" href="/blog/categories/architecture/">Architecture</a></li>
      <li><a class="filter-chip" href="/blog/categories/diagnostics/">Diagnostics</a></li>
      <li><a class="filter-chip" href="/blog/categories/fsharp/">F#</a></li>
    </ul>
    <div class="search-box">
      <span class="material-symbols-outlined" aria-hidden="true">search</span>
      <input type="text" placeholder="Search articles…" aria-label="Search articles">
    </div>
  </div>

  {%- set postCollection = collections.posts -%}
  {%- if postCollection | length > 0 -%}
  <section class="blog-grid">
    {%- for post in postCollection -%}
    {{ postCard(post, loop.first) }}
    {%- endfor -%}
  </section>
  <div class="load-row">
    <button class="load-button" type="button">Load More Articles <span class="material-symbols-outlined" aria-hidden="true">expand_more</span></button>
  </div>
  {%- else -%}
  <p class="blog-empty">No posts yet. Check back soon.</p>
  {%- endif -%}
</div>
