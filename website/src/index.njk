layout: layouts/base.njk
title: "Forge - The Future of .NET Tooling"
---

<section class="masthead">
  <div class="badge"><span class="status-dot"></span>v1.0.4 Now Available</div>
  <h1 class="title">The Future of <span>.NET Tooling</span></h1>
  <p class="lede">
    Engineered in Rust for uncompromising speed. Forge is a high-performance
    workspace designed for developers who value precision and productivity
    over bloat.
  </p>
  <div class="button-row">
    <a class="button button-primary" href="/docs/">Get Started</a>
    <a class="button button-secondary" href="https://github.com/MelbourneDeveloper/forge">
      <span class="material-symbols-outlined" aria-hidden="true">code</span>
      View on GitHub
    </a>
  </div>
</section>

<section class="panel">
  <div class="card-grid card-grid-three">
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">bolt</span>
      <h2>&lt;3s</h2>
      <p>Cold Start</p>
    </article>
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">speed</span>
      <h2>&lt;100ms</h2>
      <p>Completions</p>
    </article>
    <article class="metric-card">
      <span class="material-symbols-outlined card-icon" aria-hidden="true">extension_off</span>
      <h2>0</h2>
      <p>Proprietary Dependencies</p>
    </article>
  </div>
</section>

<section class="band">
  <div class="copy-block">
    <h2>One LSP. Every Editor.</h2>
    <p>Full Roslyn-powered completions, diagnostics, hover docs, and go-to-definition — in VS Code, Neovim, Helix, or any LSP-compatible editor.</p>
  </div>

  <div class="screenshot-frame">
    <img
      src="/assets/screenshots/vscode-hover-page.png"
      alt="Forge LSP showing hover documentation and solution explorer in VS Code"
      width="720"
      loading="eager"
    />
  </div>
</section>

<section class="panel">
  <div class="card-grid card-grid-three">
    <article class="feature-card">
      <span class="material-symbols-outlined icon-box" aria-hidden="true">explore</span>
      <h2>Smart Navigation</h2>
      <p>Instant symbol resolution and definition lookup, powered by an optimized semantic index.</p>
    </article>
    <article class="feature-card">
      <span class="material-symbols-outlined icon-box" aria-hidden="true">view_in_ar</span>
      <h2>NuGet Integration</h2>
      <p>Seamless dependency management directly from the command palette or UI.</p>
    </article>
    <article class="feature-card">
      <span class="material-symbols-outlined icon-box" aria-hidden="true">analytics</span>
      <h2>Real-time Profiling</h2>
      <p>Built-in allocation tracking and CPU profiling without context switching.</p>
    </article>
  </div>
</section>

<section class="cta">
  <div class="copy-block">
    <h2>Ready to forge ahead?</h2>
    <p>Join the open-source community shaping the next generation of .NET tooling.</p>
  </div>
  <div class="button-row">
    <a class="button button-primary" href="/docs/">Download Forge</a>
    <a class="button button-secondary" href="/docs/">Read the Docs</a>
  </div>
</section>
